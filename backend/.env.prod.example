# Copy to backend/.env.prod on the box and fill with NON-DEFAULT values.
# .env.prod is git-ignored — never commit real credentials.
DATABASE_USER=lia_prod
DATABASE_PASSWORD=<REDACTED>
DATABASE_NAME=lia_prod

# Auth: MUST be false in prod so JWTs are validated via GateGuard and the
# per-organizer event quota + file ownership are real (mock mode collapses
# every request to one principal). Access-control control — keep documented.
HTTP_MOCK_AUTH=false

# Blob storage. Defaults (set in docker-compose.prod.yml) use the local-disk
# backend with a persistent lia_uploads volume. To swap to an S3-compatible
# RU-zone provider (Yandex Object Storage, Selectel, VK Cloud, Cloud.ru) or
# self-hosted MinIO, set STORAGE_BACKEND=s3 and the S3_* vars below.
#   NOTE: the four core S3 vars are bound WITHOUT a STORAGE_ prefix; only
#   STORAGE_S3_USE_SSL carries it. (Inconsistency tracked as a follow-up.)
# STORAGE_BACKEND=s3
# S3_ENDPOINT=storage.yandexcloud.net      # e.g. s3.ru-1.storage.selcloud.ru
# S3_REGION=us-east-1                        # RU S3 endpoints accept us-east-1
# S3_BUCKET=<REDACTED>
# S3_ACCESS_KEY=<REDACTED>
# S3_SECRET_KEY=<REDACTED>
# STORAGE_S3_USE_SSL=true
# STORAGE_PUBLIC_BASE=https://api.lia.pashteto.com/api/v1/files  # or the bucket's public base

# Event-creation quota (per user, per calendar month, Europe/Moscow). Default 10.
# EVENTS_MONTHLY_LIMIT=10

# Orphaned-upload cleanup (daily in-process job). Defaults: enabled, 24h/24h.
# FILE_CLEANUP_ENABLED=true
# FILE_CLEANUP_INTERVAL=24h
# FILE_CLEANUP_GRACE=24h

# Yandex Geocoder HTTP API key (server-side secret)
YANDEX_GEOCODER_KEY=
